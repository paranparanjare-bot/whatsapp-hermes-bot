# Firebase Configuration
# Paste your Firebase Service Account JSON string here (single line)
FIREBASE_CONFIG={"type": "service_account", "project_id": "YOUR_PROJECT_ID", ...}

# Firebase Collection Name (default: baileys_session)
FIREBASE_COLLECTION=baileys_session

# Hermes API Configuration
# If your Hermes is running locally on Acer Veriton and exposed via Cloudflare Tunnel:
# HERMES_URL=https://hermes.yourdomain.com/v1/chat/completions
HERMES_URL=http://127.0.0.1:8789/v1/chat/completions
HERMES_API_KEY=your_hermes_local_api_key

# Bot Configuration
BOT_SYSTEM_PROMPT=Kamu adalah asisten AI yang cerdas, membantu, dan merespon dengan bahasa Indonesia yang natural.
IGNORE_GROUPS=true
PORT=3000
